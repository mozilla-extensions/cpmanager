content	cpmanager		content/	contentaccessible=yes
overlay	chrome://browser/content/browser.xul	chrome://cpmanager/content/cpmanager.xul
resource cpmanager modules/
locale cpmanager zh-CN locale/zh-CN/
locale cpmanager en-US locale/en-US/

interfaces components/comp.xpt
binary-component components/cpmanager-com.dll  ABI=WINNT_x86-msvc