<?xml version="1.0" encoding='UTF-8'?>
<?xml-stylesheet href="chrome://cmimprove/skin/ce-Toolbar.css" type="text/css" ?>
<!DOCTYPE window [
<!ENTITY % browserDTD SYSTEM "chrome://browser/locale/browser.dtd" >
%browserDTD;
]>
<overlay id="improve" xmlns:html="http://www.w3.org/1999/xhtml"
         xmlns="http://www.mozilla.org/keymaster/gatekeeper/there.is.only.xul">
  <script type="application/javascript" src="chrome://cmimprove/content/privateBrowser/overlay-browser.js" />

  <toolbarpalette id="BrowserToolbarPalette">
    <toolbarbutton id="ce_privateBrowser" type="button"
          class="toolbarbutton-1 toolbarbutton-ce"
          label="&privateBrowsingCmd.start.label;"
          accesskey="&privateBrowsingCmd.start.accesskey;"
          startlabel="&privateBrowsingCmd.start.label;"
          startaccesskey="&privateBrowsingCmd.start.accesskey;"
          stoplabel="&privateBrowsingCmd.stop.label;"
          stopaccesskey="&privateBrowsingCmd.stop.accesskey;"
          key="key_privatebrowsing"
          command="Tools:PrivateBrowsing"/>
  </toolbarpalette>

</overlay>
