{
    "applications": {
      "gecko": {
        "id": "cpmanager@mozillaonline.com",
        "strict_min_version": "78.0",
        "update_url": "https://archive.mozilla.org/pub/cn_pack/addons.json"
      }
    },
    "background": {
      "scripts": [
        "bg/clearHistory.js",
        "bg/tracking.js",
        "bg/undoCloseTab.js",
        "bg/gestureDragDrop.js",
        "bg/url2qr.js"
      ]
    },
    "page_action": {
      "show_matches": [ "http://*/*", "https://*/*"],
      "default_icon": {
        "16": "legacy/skin/url2qr-icon.svg",
        "32": "legacy/skin/url2qr-icon.svg",
        "64": "legacy/skin/url2qr-icon.svg"
      },
      "default_title": "__MSG_url2qrTitle__",
      "default_popup": "popup/url2qr.html"
    },
    "browser_action": {
      "browser_style": true,
      "default_area": "navbar",
      "default_icon": {
        "16": "icons/undoCloseTab-dark.svg",
        "32": "icons/undoCloseTab-dark.svg",
        "64": "icons/undoCloseTab-dark.svg"
      },
      "default_title": "__MSG_undoCloseTabTitle__",
      "theme_icons": [{
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 16
      }, {
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 32
      }]
    },
    "default_locale": "en_US",
    "description": "__MSG_extensionDescription__",
    "experiment_apis": {
      "chinaPackManager": {
        "schema": "mozillaonline/schemas/china_pack_manager.json",
        "parent": {
          "scopes": ["addon_parent"],
          "script": "mozillaonline/parent/ext-chinaPackManager.js",
          "events": ["startup"],
          "paths": [
            ["mozillaonline", "chinaPackManager"]
          ]
        }
      }
    },
    "homepage_url": "http://www.firefox.com/",
    "icons": {
      "64": "icons/extensionGeneric.svg",
      "128": "icons/extensionGeneric.svg"
    },
    "manifest_version": 2,
    "name": "__MSG_extensionName__",
    "options_ui": {
      "browser_style": true,
      "page": "options/options.html"
    },
    "permissions": [
      "<all_urls>",
      "cookies",
      "history",
      "idle",
      "menus",
      "mozillaAddons",
      "privacy",
      "scripting",
      "search",
      "sessions",
      "storage",
      "tabs"
    ],
    "version": "6.1"
  }
