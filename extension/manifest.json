{
    "applications": {
      "gecko": {
        "id": "cpmanager@mozillaonline.com",
        "strict_min_version": "68.0",
        "update_url": "https://addons.firefox.com.cn/chinaedition/addons/updates.json?reqVersion=%REQ_VERSION%&id=%ITEM_ID%&version=%ITEM_VERSION%&maxAppVersion=%ITEM_MAXAPPVERSION%&status=%ITEM_STATUS%&appID=%APP_ID%&appVersion=%APP_VERSION%&appOS=%APP_OS%&appABI=%APP_ABI%&locale=%APP_LOCALE%&currentAppVersion=%CURRENT_APP_VERSION%&updateType=%UPDATE_TYPE%&compatMode=%COMPATIBILITY_MODE%"
      }
    },
    "background": {
      "scripts": [
        "bg/clearHistory.js",
        "bg/tracking.js",
        "bg/undoCloseTab.js"
      ]
    },
    "browser_action": {
      "browser_style": true,
      "default_icon": {
        "16": "icons/undoCloseTab-dark.svg",
        "32": "icons/undoCloseTab-dark.svg",
        "64": "icons/undoCloseTab-dark.svg"
      },
      "default_title": "__MSG_undoCloseTabTitle__",
      "theme_icons": [{
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 16
      }, {
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 32
      }]
    },
    "default_locale": "en_US",
    "description": "__MSG_extensionDescription__",
    "experiment_apis": {
      "chinaPackManager": {
        "schema": "mozillaonline/schemas/china_pack_manager.json",
        "parent": {
          "scopes": ["addon_parent"],
          "script": "mozillaonline/parent/ext-chinaPackManager.js",
          "events": ["startup"],
          "paths": [
            ["mozillaonline", "chinaPackManager"]
          ]
        }
      }
    },
    "homepage_url": "http://www.firefox.com.cn/",
    "icons": {
      "64": "icons/extensionGeneric.svg",
      "128": "icons/extensionGeneric.svg"
    },
    "manifest_version": 2,
    "name": "__MSG_extensionName__",
    "options_ui": {
      "browser_style": true,
      "page": "options/options.html"
    },
    "permissions": [
      "history",
      "idle",
      "menus",
      "privacy",
      "sessions",
      "storage",
      "tabs"
    ],
    "version": "4.90"
  }
