{
    "applications": {
      "gecko": {
        "id": "cpmanager@mozillaonline.com",
        "strict_min_version": "78.0"
      }
    },
    "background": {
      "scripts": [
        "bg/clearHistory.js",
        "bg/tracking.js",
        "bg/undoCloseTab.js",
        "bg/gestureDragDrop.js"
      ]
    },
    "browser_action": {
      "browser_style": true,
      "default_area": "navbar",
      "default_icon": {
        "16": "icons/undoCloseTab-dark.svg",
        "32": "icons/undoCloseTab-dark.svg",
        "64": "icons/undoCloseTab-dark.svg"
      },
      "default_title": "__MSG_undoCloseTabTitle__",
      "theme_icons": [{
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 16
      }, {
        "light": "icons/undoCloseTab-light.svg",
        "dark": "icons/undoCloseTab-dark.svg",
        "size": 32
      }]
    },
    "default_locale": "en_US",
    "description": "__MSG_extensionDescription__",
    "experiment_apis": {
      "chinaPackManager": {
        "schema": "mozillaonline/schemas/china_pack_manager.json",
        "parent": {
          "scopes": ["addon_parent"],
          "script": "mozillaonline/parent/ext-chinaPackManager.js",
          "events": ["startup"],
          "paths": [
            ["mozillaonline", "chinaPackManager"]
          ]
        }
      }
    },
    "homepage_url": "http://www.firefox.com.cn/",
    "icons": {
      "64": "icons/extensionGeneric.svg",
      "128": "icons/extensionGeneric.svg"
    },
    "manifest_version": 2,
    "name": "__MSG_extensionName__",
    "options_ui": {
      "browser_style": true,
      "page": "options/options.html"
    },
    "permissions": [
      "history",
      "idle",
      "menus",
      "mozillaAddons",
      "privacy",
      "search",
      "sessions",
      "storage",
      "tabs"
    ],
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["contentscripts/gesture-dragdrop.js"],
        "all_frames": true,
        "run_at": "document_start"
      }
    ],
    "version": "5.114"
  }
